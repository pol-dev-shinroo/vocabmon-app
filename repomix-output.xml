export default function PixelVocabmon({
  className = "",
  feedTrigger = 0,
  attackTrigger = 0,
  specialTrigger = 0,
  level = 1,
  variant = "digimon",
}: {
  className?: string;
  feedTrigger?: number;
  attackTrigger?: number;
  specialTrigger?: number;
  level?: number;
