    return (
      <g className={glow ? "animate-pulse" : ""}>
        <rect x={x1} y={y} width="2" height="2" fill={color} />
        <rect x={x2} y={y} width="2" height="2" fill={color} />
        <rect x={x1} y={y} width="1" height="1" fill="#ffffff" />
        <rect x={x2} y={y} width="1" height="1" fill="#ffffff" />
      </g>
    );
  };

