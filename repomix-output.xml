                              </div>
                            </div>
                          </Link>
                        </div>

                        <div
                          ref={isQ3Active ? activeQuestRef : null}
                          className="relative"
                        >
                          {isQ3Active && (
                            <div className="absolute -top-3 left-4 bg-blue-500 text-white text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded-full z-20 shadow-md">
